# Unix
alias tlf="tail -f"
alias mkdir='mkdir -p'
alias ...='../..'
alias ls='ls --color=auto'
alias l='ls'
alias ll='ls -al'
alias lh='ls -Alh'
alias vimo='vim -O'
alias e="vim"
alias v="vim"

# Docker
alias d="docker"
alias dc="docker compose"
alias docker_stop_all="docker ps | awk  '{print $1}' | grep -v CON | xargs -P 5 docker stop"

# Bundler
alias b="bundle"

# Tests and Specs
alias cuc="bundle exec cucumber"

# Rubygems
alias gi="gem install"
alias giv="gem install -v"

# Rails
alias migrate="bundle exec rake db:migrate"
alias m="migrate"
alias rk="rake"
alias rs="b exec ./bin/rspec"
alias t="b exec rspec"
alias dbr="rake db:drop db:create; m"

# Shame
alias shame="rg -i '(TODO|FIXME|XXX)'"
alias SHAME="rg -i '((TODO|FIXME|XXX) ){3}'"

# git
alias gdiff="git difftool -y -x 'colordiff -y -W $COLUMNS'"
alias gpuf="echo 'Are you sure you want to force push this ? (Ctrl-c if not, sleeping 15 sec)' ;sleep 15; g push --force-with-lease"

# partical
alias mf="mdfind -onlyin ./ -name"

alias staging_go="ssh -t rm-st-dk-02 sudo sg_docker_exec_app bash"

# Pipe my public key to my clipboard.
alias pubkey="more ~/.ssh/zaratan.pub | pbcopy | echo '=> Public key copied to pasteboard.'"

alias sp="spotify"
alias vim="nvim -O"

alias raf="rubocop -P -f fi | xargs rubocop -A"
alias dop="dev_oops"

# BAT == CAT
command -v bat >/dev/null && alias cat="bat --paging=never"

# DUST > DU
command -v dust >/dev/null && alias du="dust"

# DUF > DF
command -v duf >/dev/null && alias df="duf --theme dark"

# Moor is less
command -v moor >/dev/null && alias less="moor"
alias python="python3"

# Dev Oops
alias doo="dev_oops"
alias calc="bc --expression"
alias p="pnpm"
