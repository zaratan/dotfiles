.DS_Store
__pycache__/
Brewfile.lock.json
Brewfile.local
*.bak
.ruby-lsp/

# Claude memory is personal: never in the repo
config/claude/.claude/memory/
# Per-machine Claude permissions: never in the repo
**/.claude/settings.local.json

# Spell files are re-downloaded by nvim on demand
config/nvim/.config/nvim/spell/
# lazy.nvim lockfile stays local on purpose (always latest plugins)
config/nvim/.config/nvim/lazy-lock.json

# OrbStack recreates its symlinks in ~/bin (= config/bin/bin through stow)
config/bin/bin/docker*
config/bin/bin/kubectl
config/bin/bin/orb*
