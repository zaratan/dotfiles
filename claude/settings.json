{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(dev_oops lint:*)",
      "Bash(bundle exec rails runner:*)",
      "Bash(git show:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(claude mcp:*)",
      "mcp__sentry__get_issue_details",
      "Bash(bin/rails db:rollback:*)",
      "Bash(bin/rails db:migrate:*)",
      "Bash(ls:*)",
      "Bash(bin/rails routes:*)",
      "Bash(bundle exec rails routes:*)",
      "mcp__sentry__find_organizations",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:support.google.com)",
      "mcp__github__get_pull_request_comments",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "WebFetch(domain:heroicons.com)",
      "WebFetch(domain:guides.rubyonrails.org)",
      "Bash(bundle exec rubocop:*)",
      "mcp__sentry__search_issues",
      "Bash(bundle outdated:*)",
      "Bash(gem specification:*)",
      "Bash(ruby -v:*)",
      "Bash(yarn outdated:*)",
      "WebFetch(domain:rubyreferences.github.io)",
      "WebFetch(domain:ddnexus.github.io)",
      "Bash(ruby -ryaml -e:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(bundle audit:*)",
      "Bash(bin/rails g:*)",
      "Bash(bin/rails runner:*)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "language": "Français"
}
